  "summaries": [
    {
      "id": 26326,
      "category": "team",
      "content": " In the TikTok Ads portal, if both invited Ad Accounts are part of the same business group, an exposed endpoint could potentially be exploited to view email address, phone number, company, and name of the Ad Account owner. We thank @emanuelharijanto for reporting this to our team and confirming the resolution!",
      "updated_at": "2021-01-20T22:48:13.246Z",
      "can_view?": true,
      "can_create?": false,
      "attachments": [],
