  "summaries": [
    {
      "id": 16134,
      "category": "team",
      "content": "Our Security Team was notified by researchers who identified a valid leaked Github token in Travis CI logs that allow accessing a limited number of Grammarly repositories. We immediately revoked the token and conducted investigation together with the Github support team. Based on the available access log data, we have enough evidence to state that any other party did not use the token to access our repositories.\n\nWe want to thank @karimpwnz and @cdl for providing a detailed report, efficient communication, and further verification actions.",
      "updated_at": "2019-05-22T12:05:52.106Z",
      "can_view?": true,
      "can_create?": false,
