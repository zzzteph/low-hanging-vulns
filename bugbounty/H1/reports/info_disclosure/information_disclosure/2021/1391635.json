  "summaries": [
    {
      "id": 164760,
      "category": "team",
      "content": "Cloudflare Deception Armor could be bypassed by using `.avif` extension making Cache deception attack possible on vulnerable origin servers.\nCloudflare Cache Deception Armor uses a Page rule to protect Cloudflare Cache against caching possibly sensitive information. \nThis attack could be performed by tricking a user into clicking a crafted URL (using \"path confusion techniques\") ending with an `.avif` extension which makes Cloudflare edge cache the returned (normally non-cachable) content. An attacker could then retrieve this cached information from Cloudflare's edge.\nThe page rule was improved to better handle .avif formats and the presented bypass is no longer possible.",
      "updated_at": "2022-06-27T16:19:53.781Z",
      "can_view?": true,
      "can_create?": false,
      "attachments": [],
      "user": {
        "id": 1982826,
        "username": "m0nia",
        "name": "Monika S",
        "bio": "",
        "cleared": false,
        "verified": false,
        "website": null,
