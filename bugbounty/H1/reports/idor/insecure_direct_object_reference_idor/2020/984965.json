  "summaries": [
    {
      "id": 36546,
      "category": "team",
      "content": "Due to an Insecure Direct Object Reference (IDOR) vulnerability, an attacker could have potentially added, deleted, or updated rules for other users' pixel events in the TikTok ads portal. We thank @bubbounty for reporting this to our team and confirming the resolution. ",
      "updated_at": "2021-04-02T21:16:31.762Z",
      "can_view?": true,
      "can_create?": false,
