  "summaries": [
    {
      "id": 345633,
      "category": "team",
      "content": "Cloudflare's Dashboard enables users to configure 2-Factor Authentication using a Security Key. An issue in the authentication system allowed for the retrieval of recovery codes (used to regain account access if the security key is lost) after verifying the username and password but before completing the authentication process by touching the Security Key. Cloudflare's Engineering team resolved the issue by disallowing requests to the vulnerable API endpoint until users are fully authenticated.\n",
      "updated_at": "2023-09-18T12:25:09.333Z",
      "can_view?": true,
      "can_create?": false,
