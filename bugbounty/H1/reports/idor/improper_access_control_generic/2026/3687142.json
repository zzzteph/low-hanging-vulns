  "summaries": [
    {
      "id": 864830,
      "category": "team",
      "content": "Protected file downloads at `/file-upload/:fileId/:name` authorize livechat access using `rc_room_type=l` with `rc_rid+rc_token`, but the authorization path does not verify that `rc_rid` matches the requested file's `rid`. Furthermore, `:fileId` is predictable via sequential MongoDB IDs, and `:name` can be anything, allowing unauthenticated discovery of all uploaded files.",
      "updated_at": "2026-06-15T23:40:53.198Z",
