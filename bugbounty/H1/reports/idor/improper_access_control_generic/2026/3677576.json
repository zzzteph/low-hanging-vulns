  "summaries": [
    {
      "id": 857664,
      "category": "team",
      "content": "HackerOne community member barcrange (3l4) has reported a missing access control check when invoking various modify methods in the XML‑RPC API of Revive Adserver 6.0.6 and earlier. The API allowed entities to be reassigned to different parent entities, leading to inconsistent ownership relationships. This issue was exploitable only in combination with CVE‑2026‑34917 or with third‑party API extensions that expose API functionality to low‑privileged users.\n\nAccess control checks have been added to validate access to parent entities in the API modify methods.\n",
      "updated_at": "2026-05-22T15:29:18.386Z",
