  "summaries": [
    {
      "id": 877874,
      "category": "team",
      "content": "The `/get_alt_blocks_hashes` RPC endpoint was restricted to prevent unintended access to alternative block hashes. The endpoint had previously been unrestricted. The issue was assessed as low severity due to the limited impact and the availability of similar information through other mechanisms.",
      "updated_at": "2026-07-19T23:20:33.230Z",
