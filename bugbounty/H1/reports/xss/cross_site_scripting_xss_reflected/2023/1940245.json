  "summaries": [
    {
      "id": 396189,
      "category": "team",
      "content": "The `returnTo` parameter on `help.shopify.com/en/support/confirm-account-details` was vulnerable to XSS by using the `javascript:` protocol for the URL. In this case, the exploit relies on:\n\n1. an account being in an incomplete state\n2. the account holder clicking on the exploit URL\n3. the account holder logging into help.shopify.com\n4. the account holder clicking the continue button",
