          "xtralarge": "https://profile-photos.hackerone-user-content.com/variants/e7YSYHJbCxRkTMx3w2a92mts/d6d8259739a2a4d509639b7804214d057bca547cc3fafe509ec3e3a86321b1d1"
        }
