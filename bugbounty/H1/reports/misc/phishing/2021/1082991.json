    {
      "id": 26360,
      "category": "researcher",
      "content": "In the internal browser of the LINE iOS application, there was a flaw in the implementation of displaying the address bar of HTTP redirect processing. It was improperly normalized by inserting malicious Unicode character into the domain name.\nAs a result, the domain name and the content of the displayed web page did not match, and Address Bar Spoofing was possible.",
      "updated_at": "2021-09-15T04:44:54.297Z",
      "can_view?": true,
      "can_create?": false,
      "attachments": [],
